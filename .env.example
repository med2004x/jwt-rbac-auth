APP_NAME=jwt-rbac-auth
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=postgresql+asyncpg://auth_user:auth_password@postgres:5432/auth_service
MIGRATION_DATABASE_URL=postgresql://auth_user:auth_password@postgres:5432/auth_service
REDIS_URL=redis://redis:6379/0
